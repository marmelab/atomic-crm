# ============================================
# Copy this file to .env.local and fill in your real keys
# .env.local is gitignored — never commit real secrets
# ============================================

# Supabase local config
POSTMARK_WEBHOOK_USER=testuser
POSTMARK_WEBHOOK_PASSWORD=testpwd
VITE_INBOUND_EMAIL=your-inbound-email@inbound.postmarkapp.com
POSTMARK_WEBHOOK_AUTHORIZED_IPS=3.134.147.250,50.31.156.6,50.31.156.77,18.217.206.57,172.18.0.1,172.19.0.1,192.168.65.1,172.20.0.1
SB_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
SB_PUBLISHABLE_KEY=your-sb-publishable-key
API_EXTERNAL_URL=http://127.0.0.1:54321

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Enrichment - Google Custom Search (for social media discovery)
GOOGLE_CUSTOM_SEARCH_API_KEY=your-google-custom-search-api-key
GOOGLE_CUSTOM_SEARCH_CX=your-programmable-search-engine-id

# Enrichment - Serper.dev (Google search for website discovery)
SERPER_API_KEY=your-serper-api-key-here

# Quote system - Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Quote system - Docuseal e-signing
DOCUSEAL_API_KEY=your-docuseal-api-key-here
DOCUSEAL_BASE_URL=https://api.docuseal.com
DOCUSEAL_TEMPLATE_ID=your-template-id-here
DOCUSEAL_WEBHOOK_SECRET=your-webhook-secret-here

# Resend - outbound email
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=hej@axonadigital.se
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret-here

# Sequence processor - cron auth
CRON_SECRET=your-cron-secret-here

# Discord bot integration
DISCORD_BOT_SECRET=your-discord-bot-secret-here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url-here

# Synlighet (analyze_website) — valfria, gated. Saknas de hoppas källan över.
# Lokal map-pack-rank (Fas 2B) via DataForSEO:
DATAFORSEO_LOGIN=your-dataforseo-login-here
DATAFORSEO_PASSWORD=your-dataforseo-password-here
