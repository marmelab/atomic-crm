# Auto-increment patch version in src/version.ts (format: vX.Y.Z)
VERSION_FILE="src/version.ts"
CURRENT=$(grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' "$VERSION_FILE" | head -1)
PATCH=$(echo "$CURRENT" | grep -oE '[0-9]+$')
PREFIX=$(echo "$CURRENT" | grep -oE '^v[0-9]+\.[0-9]+\.')
NEXT="${PREFIX}$((PATCH + 1))"
printf 'export const APP_VERSION = "%s";\n' "$NEXT" > "$VERSION_FILE"
git add "$VERSION_FILE"

make registry-gen || true
